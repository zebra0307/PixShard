PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pixshard?retryWrites=true&w=majority
CLIENT_URL=https://pixshard.web.app

# Firebase project ID (from Firebase Console)
FIREBASE_PROJECT_ID=pixshard

# Firebase service account key — TWO OPTIONS:
#
#   Option A — Local dev (file path):
#     Download: Firebase Console → Project Settings → Service accounts → Generate new private key
#     Save as api/serviceAccountKey.json  (already in .gitignore)
FIREBASE_SERVICE_ACCOUNT=./serviceAccountKey.json
#
#   Option B — Render / Railway (paste JSON string directly as env var):
#     Open the downloaded JSON, copy ALL content, paste as one line in the dashboard
#     FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"pixshard",...}

# Path to logic/ folder (self-contained inside api/)
LOGIC_DIR=./logic
