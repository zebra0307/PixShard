# ─────────────────────────────────────────────────
#  PixShard — .gitignore
# ─────────────────────────────────────────────────

# ── OS / Editor ──────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/settings.json

#logic
./Secret_Sharing_schemes

# ── Node ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
package-lock.json

# ── React build output (Vercel builds this itself)
client/dist/
client/.env.local

# ── API secrets ──────────────────────────────────
api/.env
api/.env.local

# ── Runtime-generated data dirs (keep .gitkeep) ──
# Ignore all contents but keep the empty-dir placeholder
api/uploads/*
!api/uploads/.gitkeep
api/images/*
!api/images/.gitkeep
api/public_datas/*
!api/public_datas/.gitkeep

# Firebase service account key (contains private key — NEVER commit)
api/serviceAccountKey.json
**/serviceAccountKey*.json

# ── Firebase CLI (no longer used — using Vercel) ─
.firebase/
firebase.json
.firebaserc

# ── Python ───────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# ── NumPy binary share files ─────────────────────
*.npy
*.npz

# ── Logs & archives ──────────────────────────────
*.log
logs/
*.zip
*.tar.gz
