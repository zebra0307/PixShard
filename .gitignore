# ────────────────────────────────────────────────
#  PixShard — Root .gitignore
# ────────────────────────────────────────────────

# ── OS / Editor ─────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/settings.json

# ── Node ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── React build output ──────────────────────────
client/dist/
client/.env.local

# KEEP client/.env.production (contains VITE_API_BASE_URL — no secrets)

# ── Express API: secrets & runtime data ─────────
api/.env
api/.env.local

# Multer temp / generated share files (large, runtime only)
api/uploads/
api/images/
api/public_datas/

# Firebase service account key (NEVER commit — contains private key)
api/serviceAccountKey.json
**/serviceAccountKey*.json

# ── Firebase CLI cache ───────────────────────────
.firebase/

# ── Python ──────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/
env/

# Binary share files (large NumPy arrays)
*.npy
*.npz

# ── Logs ────────────────────────────────────────
logs/
*.log

# ── Archives ────────────────────────────────────
*.zip
*.tar.gz

# ── Test / scratch ───────────────────────────────
/tmp/
scratch/
