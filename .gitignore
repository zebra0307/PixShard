# ─────────────────────────────────────────────────
#  PixShard — .gitignore
# ─────────────────────────────────────────────────

# ── OS / Editor ──────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/settings.json

#logic
./Secret_Sharing_schemes

# ── Node ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
package-lock.json

# ── React build output (Vercel builds this itself)
client/dist/
client/.env.local

# ── API secrets & runtime-generated data ─────────
api/.env
api/.env.local
api/uploads/
api/images/
api/public_datas/

# Firebase service account key (contains private key — NEVER commit)
api/serviceAccountKey.json
**/serviceAccountKey*.json

# ── Firebase CLI (no longer used — using Vercel) ─
.firebase/
firebase.json
.firebaserc

# ── Python ───────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# ── NumPy binary share files ─────────────────────
*.npy
*.npz

# ── Logs & archives ──────────────────────────────
*.log
logs/
*.zip
*.tar.gz
